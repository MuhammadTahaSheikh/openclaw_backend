# Hostinger MySQL (from hPanel → Databases)
DB_HOST=your-mysql-host.hstgr.io
DB_PORT=3306
DB_NAME=u916710688_openclaw
DB_USER=u916710688_openclaw_ai
DB_PASSWORD=your_password_here

# Set to true if Hostinger requires SSL for remote connections
DB_SSL=false

# Server
PORT=3000

# Auth (JWT)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Initial admin user (created on first startup if no users exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

# Frontend URL (used in invite emails)
FRONTEND_URL=http://localhost:5173

# Invite link expiry (hours)
INVITE_EXPIRES_HOURS=72

# Email via Resend (recommended — no SMTP needed)
# https://resend.com — domain must be verified for custom FROM address
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=OpenClaw <noreply@yourdomain.com>
INVITE_REPLY_TO=info@yourdomain.com
SUPPORT_EMAIL=info@yourdomain.com

# Email via SMTP (optional fallback if RESEND_API_KEY is not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=OpenClaw <your-email@gmail.com>
